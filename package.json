{
  "name": "rihapdf",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@11.0.5",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "check": "tsc -b && oxfmt --check && oxlint src test *.js *.mjs *.config.ts *.config.js *.config.mjs",
    "check:ci": "tsc -b && oxfmt --check --threads=1 && oxlint --threads=1 src test *.js *.mjs *.config.ts *.config.js *.config.mjs",
    "lint": "oxlint src test *.js *.mjs *.config.ts *.config.js *.config.mjs",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "preview": "vite preview",
    "test": "vitest run test/unit",
    "test:unit": "vitest run test/unit",
    "test:e2e": "node scripts/withViteServer.mjs",
    "test:all": "pnpm run test:unit && pnpm run test:e2e",
    "test:coverage": "vitest run test/unit --coverage",
    "test:e2e:coverage": "node scripts/withViteServer.mjs --coverage",
    "test:fixtures": "node test/fixtures/build.mjs",
    "cf:config": "node scripts/writeWranglerConfig.mjs",
    "cf:dev": "wrangler dev",
    "cf:deploy": "pnpm build && wrangler deploy"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@heroui/react": "^3.0.3",
    "@heroui/styles": "^3.0.3",
    "@lexical/react": "0.44.0",
    "@lexical/rich-text": "0.44.0",
    "@lexical/selection": "0.44.0",
    "@lexical/utils": "0.44.0",
    "@pdf-lib/fontkit": "^1.1.1",
    "bidi-js": "^1.0.3",
    "framer-motion": "^12.38.0",
    "harfbuzzjs": "^0.10.3",
    "lexical": "0.44.0",
    "lucide-react": "^1.14.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^5.7.284",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.63.0",
    "oxlint-tailwindcss": "^0.7.1",
    "oxlint-tsgolint": "^0.22.1",
    "playwright": "^1.59.1",
    "tailwindcss": "^4.2.4",
    "typescript": "~6.0.2",
    "vite": "^8.0.10",
    "vitest": "^4.1.5",
    "wrangler": "^4.88.0"
  }
}
